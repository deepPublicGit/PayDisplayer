{
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://linkedin.com/jobs/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "manifest_version": 3,
  "name": "pay-displayer",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://www.linkedin.com/jobs/*",
    "https://www.levels.fyi/*"
  ],
  "version": "0.1"
}